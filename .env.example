# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

APP_NAME=Auto Intel Demo
APP_HOST=127.0.0.1
APP_PORT=8018

# SQLite (default) — change to PostgreSQL URL for production
DATABASE_URL=sqlite:///./data/demo.db

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TRIGGER=cron
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_CRON_HOUR=5
SCHEDULER_CRON_MINUTE=0

# Collection behaviour
BRIEFING_FOLLOWUP_DAYS=5
COLLECT_LIMIT_PER_SOURCE=12
LOOKBACK_HOURS=72

# Timeouts (seconds)
REQUEST_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS=120

# DeepSeek API — required for article analysis and translation
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
